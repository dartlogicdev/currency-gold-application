<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:gravity="center_vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="KaratExchange"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:alpha="0.9" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:alpha="0.6"
            android:layout_marginEnd="8dp" />

        <!-- Rechner-Button -->
        <TextView
            android:id="@+id/btn_calculator"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="🧮"
            android:textSize="16sp"
            android:gravity="center"
            android:background="@drawable/button_background" />
    </LinearLayout>

    <!-- Divider -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginBottom="8dp" />

    <!-- Pair 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/pair1_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EUR/USD"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/pair1_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Pair 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/pair2_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EUR/TRY"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/pair2_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Pair 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/pair3_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="EUR/GBP"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/pair3_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Gold -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/gold_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🥇 Gold/g"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:alpha="0.8" />

        <TextView
            android:id="@+id/gold_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-"
            android:textColor="#FFD700"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
